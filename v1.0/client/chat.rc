IDR_MAINFRAME MENU PRELOAD DISCARDABLE 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New Connection...\tCtrl+N",  ID_FILE_NEW
        MENUITEM "&Open...\tCtrl+O",            ID_FILE_OPEN
        MENUITEM "&Save\tCtrl+S",               ID_FILE_SAVE
        MENUITEM "Save &As...",                 ID_FILE_SAVE_AS
        MENUITEM "&Create Shortcut",            ID_FILE_CREATESHORTCUT
        MENUITEM SEPARATOR
        MENUITEM "&Print...\tCtrl+P",           ID_FILE_PRINT
        MENUITEM "P&rint Setup...",             ID_FILE_PRINT_SETUP
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X",                ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C",               ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
        MENUITEM "C&lear\tDel",                 ID_EDIT_DELETE
        MENUITEM SEPARATOR
        MENUITEM "Select &All\tCtrl+A",         ID_EDIT_SELECTALL
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Status Bar",                 ID_VIEW_STATUS_BAR
        MENUITEM SEPARATOR
        MENUITEM "&Comic Strip",                ID_VIEW_COMICS
        MENUITEM "Plain Te&xt",                 ID_VIEW_TEXT
        MENUITEM SEPARATOR
        POPUP "&Member List"
        BEGIN
            MENUITEM "&List",                       ID_VIEW_LIST
            MENUITEM "&Icon",                       ID_VIEW_ICON
        END
        MENUITEM SEPARATOR
        MENUITEM "Chat Room &List ...",         ID_CHATROOM_LIST
        MENUITEM SEPARATOR
        MENUITEM "&Options...\tCtrl+Q",         ID_VIEW_OPTIONS
    END
    POPUP "&Session"
    BEGIN
        MENUITEM "&New Room...",                ID_SESSION_NEWROOM
        MENUITEM "&Leave Room",                 ID_SESSION_LEAVE
        MENUITEM SEPARATOR
        MENUITEM "&Connect...",                 ID_SESSION_CONNECT
        MENUITEM "&Disconnect",                 ID_SESSION_DISCONNECT
    END
    POPUP "&Member"
    BEGIN
        MENUITEM "&Get Profile",                ID_MEMBER_GETINFO
        MENUITEM "&Ignore",                     ID_MEMBER_IGNORE
    END
    POPUP "F&avorites"
    BEGIN
        MENUITEM "&Add To Favorites",           ID_FAVORITES_ADDTOFAVORITES
        MENUITEM "&Open Favorites...",          ID_FAVORITES_OPENFAVORITES
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&Help Topics",                ID_HELP_TOPICS
        MENUITEM SEPARATOR
        MENUITEM "&About Microsoft Comic Chat", ID_APP_ABOUT
    END
END

