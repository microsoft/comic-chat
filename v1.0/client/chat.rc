IDD_BOTHER DIALOG DISCARDABLE  0, 0, 186, 76
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Tip - Sending Text"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,67,55,50,14
    LTEXT           "To send the text that you have typed, press ENTER or press one of the buttons to the right of where you typed.",
                    IDC_STATIC,15,10,160,30
    CONTROL         "Please do not ask me again.",IDC_BOTHER,"Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,15,40,155,10
END

IDD_SETTINGSPAGE DIALOG DISCARDABLE  0, 0, 252, 218
STYLE WS_CHILD | WS_DISABLED | WS_CAPTION | WS_SYSMENU
CAPTION "Settings"
FONT 8, "MS Sans Serif"
BEGIN
    CONTROL         "Prompt to &save the conversation on exit.",IDC_SAVE,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,126,160,10
    CONTROL         "Don't send &graphics information.",IDC_COMICSDATA,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,14,100,120,10
    COMBOBOX        IDC_PANELS,14,44,91,60,CBS_DROPDOWNLIST | CBS_SORT | 
                    WS_VSCROLL | WS_TABSTOP
    GROUPBOX        "Page Layout",IDC_STATIC,7,5,236,60
    GROUPBOX        "Connection",IDC_STATIC,7,70,236,45
    LTEXT           "If you are speaking to someone who is not using Comic Chat, check the box below:",
                    IDC_STATIC,15,81,205,17
    LTEXT           "You may change how many panels Comic Chat uses horizontally to display the comic strip.  On some computers this may cause the window to scroll horizontally.",
                    IDC_STATIC,15,15,208,25
END

