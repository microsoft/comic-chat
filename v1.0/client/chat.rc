IDD_SETUPDIALOG DIALOG DISCARDABLE  0, 0, 176, 156
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Connect"
FONT 8, "MS Sans Serif"
BEGIN
    LTEXT           "&Favorites:",IDC_STATIC,7,7,32,8
    COMBOBOX        IDC_CHATROOMS,7,21,161,63,CBS_DROPDOWNLIST | CBS_SORT | 
                    WS_VSCROLL | WS_TABSTOP
    LTEXT           "&Server:",IDC_STATIC,7,42,24,9
    EDITTEXT        IDC_SERVER,7,56,126,14,ES_AUTOHSCROLL
    LTEXT           "&Port:",IDC_STATIC,140,42,22,8
    EDITTEXT        IDC_PORTNUM,140,56,28,14,ES_AUTOHSCROLL
    CONTROL         "",IDC_STATIC,"Static",SS_ETCHEDHORZ,7,81,162,1
    CONTROL         "Go to chat room:",IDC_CONCHAN,"Button",
                    BS_AUTORADIOBUTTON | WS_GROUP,7,93,69,10
    CONTROL         "Show all available chat rooms.",IDC_LISTCHAN,"Button",
                    BS_AUTORADIOBUTTON,7,107,111,10
    EDITTEXT        IDC_CHANNEL,77,91,91,14,ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK",IDOK,7,133,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,63,133,50,14
    PUSHBUTTON      "&Help",IDC_SETUPHELP,119,133,50,14
END

IDD_ABOUTBOX DIALOG DISCARDABLE  34, 22, 278, 186
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About Microsoft Comic Chat"
FONT 8, "Comic Sans MS"
BEGIN
    CONTROL         "Comic Chat Version %1.%2.%3.%4",IDC_VERSION,"Static",
                    SS_LEFTNOWORDWRAP | WS_GROUP,7,4,105,8
    DEFPUSHBUTTON   "OK",IDOK,226,168,47,14,WS_GROUP
    LTEXT           "Warning:  This computer program is protected by copyright law and international treaties.  Unauthorized reproduction or distribution of this program, or any portion of it, may result in severe civil and criminal penalties.",
                    IDC_WARNING,7,132,131,50,NOT WS_GROUP
    LTEXT           "Microsoft Corporation",IDC_CORP,159,20,103,8
    LTEXT           "Beta user",IDC_USER,159,12,103,8
    LTEXT           "Copyright © 1996  Microsoft Corporation",IDC_COPY,7,12,
                    134,8
    GROUPBOX        "This product is licensed to",IDC_LICENSE,153,4,120,28
    CONTROL         203,IDC_TIKI,"Static",SS_BITMAP | SS_CENTERIMAGE | 
                    SS_REALSIZEIMAGE,0,0,280,186
END

