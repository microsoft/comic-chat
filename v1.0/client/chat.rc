 FILEFLAGS 0x0L
#endif
 FILEOS 0x4L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Microsoft Corporation\0"
            VALUE "FileDescription", "Microsoft Comic Chat\0"
            VALUE "FileVersion", "1.00\0"
            VALUE "InternalName", "CHAT\0"
            VALUE "LegalCopyright", "Copyright © Microsoft Corp. 1996\0"
            VALUE "OriginalFilename", "CHAT.EXE\0"
            VALUE "ProductName", "Microsoft Comic Chat\0"
            VALUE "ProductVersion", "1.0\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

