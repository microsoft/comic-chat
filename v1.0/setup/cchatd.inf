[Version]
Signature="$CHICAGO$"
Provider=%MSFT%
AdvancedINF=2.0

[DefaultInstall]
CopyFiles      = ProductFiles, HelpFiles, InfFiles, AvatarFiles, BackdropFiles
UpdateInis     = CChatInis
AddReg         = CChatReg
OptionDesc     = %CChatDesc%
Tip            = %CChatTop%
Parent         = AccessTop
InstallType    = 10
IconIndex      = 39  ;Windows Logo mini-icon for dialogs
Uninstall      = CChatUninstall

[CChatUninstall]
DelFiles       = ProductFiles, HelpFiles, InfFiles, AvatarFiles, BackdropFiles
UpdateInis	   = CChatDelInis
DelReg         = CChatDelReg

[DestinationDirs]
ProductFiles   = 24,%OEM_PROGRAMF%\%CChatDir%
HelpFiles	   = 18
InfFiles	   = 17    
AvatarFiles    = 24,%OEM_PROGRAMF%\%CChatDir%\ComicArt\Avatars
BackdropFiles  = 24,%OEM_PROGRAMF%\%CChatDir%\ComicArt\Backdrop

[ProductFiles]
CHATD.EXE
CHAT.PDB
TITLES.TXT  	
README.HTM   
LICENSE.TXT 	
	
[HelpFiles]
CCHAT.HLP
CCHAT.CNT

[InfFiles]
CCHATD.INF

[AvatarFiles]
JORDAN.AVB
HUGH.AVB
MIKE.AVB
SUSAN.AVB
ARMANDO.AVB
XENO.AVB
TIKI.AVB
