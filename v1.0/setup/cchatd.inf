[CChatInis]
setup.ini, progman.groups,, "group100=%CChatGroup%"
setup.ini, group100,, """%CChat_LINK%"", %24%\%PROGRAMF%\%CCHATDIR%\ChatD.EXE,,, CChat"

[CChatDelInis]
setup.ini, progman.groups,, "group100=%CChatGroup%"
setup.ini, group100,, """%CChat_LINK%"""

[CChatReg]
HKCR,".ccr",,,"ccr_auto_file"
HKCR,"ccr_auto_file",,,"Comic Chat Room"
HKCR,"ccr_auto_file\shell",,,"open"
HKCR,"ccr_auto_file\shell\open",,,""
HKCR,"ccr_auto_file\shell\open","EditFlags",1,01,00,00,00
HKCR,"ccr_auto_file\shell\open\command",,,"c:\%Program_Files%\cchat\chatd.exe \""%%1\"""
HKCR,".ccc",,,"ccc_auto_file"
HKCR,"ccc_auto_file",,,"Comic Chat Conversation"
HKCR,"ccc_auto_file\shell",,,"open"
HKCR,"ccc_auto_file\shell\open",,,""
HKCR,"ccc_auto_file\shell\open","EditFlags",1,01,00,00,00
HKCR,"ccc_auto_file\shell\open\command",,,"c:\%Program_Files%\cchat\chatd.exe \""%%1\"""
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}",,,"Comic Chat Room"
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\Verb",,,""
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\Verb\0",,,"&Edit,0,2"
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\Verb\1",,,"&Open,0,2"
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\Insertable",,,""
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\AuxUserType",,,""
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\AuxUserType\2",,,"Room"
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\AuxUserType\3",,,"chat"
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\MiscStatus",,,"32"
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\ProgID",,,"ComicChat.Room.1"
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\InprocHandler32",,,"ole32.dll"
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\LocalServer32",,,"c:\%Program_Files%\cchat\chatd.exe"
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\DefaultIcon",,,"c:\%Program_Files%\cchat\chatd.exe,1"
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\DocObject",,,"0"
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\Printable",,,""
HKCR,"clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\DefaultExtension",,,".ccr,Comic Chat Room (*.ccr)"
HKCR,"ComicChat.Room.1",,,"Comic Chat Room"
HKCR,"ComicChat.Room.1\Insertable",,,""
HKCR,"ComicChat.Room.1\protocol",,,""
HKCR,"ComicChat.Room.1\protocol\StdFileEditing",,,""
HKCR,"ComicChat.Room.1\protocol\StdFileEditing\verb",,,""
HKCR,"ComicChat.Room.1\protocol\StdFileEditing\verb\0",,,"&Edit"
HKCR,"ComicChat.Room.1\protocol\StdFileEditing\server",,,"c:\%Program_Files%\cchat\chatd.exe"
HKCR,"ComicChat.Room.1\CLSID",,,"{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}"
HKCR,"ComicChat.Room.1\DocObject",,,"0"
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\RenameFiles\AppFilesRoot,,,%24%
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\RenameFiles\AppFilesRoot,%OLD_PROGRAMF%,,"%Old_Program_Files%" ; review - leave in for M8
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\RenameFiles\AppFilesRoot,%PROGRAMF%,,!$!$!$!$.$!$
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\RenameFiles\AppFilesRoot,!$!$!$!$.$!$,,"%Program_Files%,1"
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\RenameFiles\AppFiles,,,"%24%\%PROGRAMF%"
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\RenameFiles\AppFiles,%ACCESSOR%,,!$!$!$!$.$!$
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\RenameFiles\AppFiles,!$!$!$!$.$!$,,"%Accessories%,1"
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\ComicChat,"DisplayName",,"%CChatName%"
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\ComicChat,"UninstallString",,"RunDll setupx.dll,InstallHinfSection CChatUninstall 4 cchatd.inf"
HKLM,"SOFTWARE\Microsoft\Windows\CurrentVersion\App Paths\Chatd.EXE",,,"%24%\%PROGRAMF%\CChat\Chatd.EXE"

[CChatDelReg]
HKCR,.ccr
HKCR,ccr_auto_file
HKCR,.ccc
HKCR,ccc_auto_file
HKCR,clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\ComicChat
HKCR,ComicChat.Room.1
HKCU,SOFTWARE\Microsoft\%CChatName%

[Strings]
CChatGroup			= "Microsoft Comic Chat"
CChatName			= "Microsoft Comic Chat"
CChatDir			= "CChat"
CChat_LINK			= "Microsoft Comic Chat"
CChatDesc			= "CChat"
CChatTop			= "Microsoft Comic Chat"
Program_Files		= "Program Files"
Old_Program_Files	= "Old Program Files" 
OLD_PROGRAMF		= "Programf"          
PROGRAMF			= "Progra~1"          
OEM_PROGRAMF		= "Progra~1"          
Accessories			= "CChat"
ACCESSOR			= "CChat"          
DiskName			= "Microsoft Comic Chat Installation Disk"

