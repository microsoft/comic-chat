FC_NEU_S.BMP	
FC_SAD_L.BMP
FC_SAD_S.BMP	
FC_SCA_L.BMP	
FC_SCA_S.BMP	
FC_SHO_L.BMP	
FC_ANG_L.BMP

[BackdropFiles]
ROOM8BS.BMP 
FIELD.BMP
PASTORAL.BMP

[SourceDisksNames]
1 = %DiskName%,CChat,0

[SourceDisksFiles]
CHATD.EXE		= 1
CHAT.PDB		= 1
TITLES.TXT  	= 1
README.TXT  	= 1
LICENSE.TXT 	= 1
CCHAT.HLP		= 1
CCHAT.CNT		= 1
CCHATD.INF              = 1
JORDAN.AVB		= 1
HUGH.AVB		= 1
MIKE.AVB		= 1
SUSAN.AVB		= 1
ARMANDO.AVB		= 1
XENO.AVB		= 1
TIKI.AVB		= 1
LANCE.AVB		= 1
DAN.AVB			= 1
MARGARET.AVB	= 1
TONGTYED.AVB	= 1
ANNA.AVB		= 1
FC_SHO_S.BMP	= 1
FC_ANG_S.BMP	= 1
FC_BOR_L.BMP	= 1
FC_BOR_S.BMP	= 1
