; CChat2.INF
;
; This is the Setup information file to install 
; Microsoft Comic Chat.
;
; Copyright (c) 1993-1996 Microsoft Corporation
;

[Version]
Signature="$CHICAGO$"
Provider=%MSFT%
AdvancedINF=2.5, "You need a newer version of Advpack.dll."  

[DefaultInstall]
CopyFiles      = ProductFiles, HelpFiles, InfFiles, ArtFiles, SysFiles
UpdateInis     = CChatDelOldInis, CChatInis
AddReg         = CChatReg
OptionDesc     = %CChatDesc%
Tip            = %CChatTop%
Parent         = AccessTop
InstallType    = 10
IconIndex      = 39  ;Windows Logo mini-icon for dialogs
Uninstall      = CChatUninstall
CustomDestination = MyCustomDestination
DelFiles       = OldInfFiles
DelReg         = CChatDelOldReg
PerUserInstall = MSChat.Stub.Add

[DefaultInstall.NT]
CopyFiles      = ProductFiles, HelpFiles, InfFiles, ArtFiles, SysFiles
UpdateInis     = CChatDelOldInis,CChatInis.NT
AddReg         = CChatReg
OptionDesc     = %CChatDesc%
Tip            = %CChatTop%
Parent         = AccessTop
InstallType    = 10
IconIndex      = 39  ;Windows Logo mini-icon for dialogs
Uninstall      = CChatUninstall
CustomDestination = MyCustomDestination
DelFiles       = OldInfFiles
DelReg         = CChatDelOldReg
PerUserInstall = MSChat.Stub.Add.NT

[CChatUninstall]
SmartReboot = I
DelFiles       = ProductFiles, HelpFiles, ArtFiles
UpdateInis     = CChatDelInis
DelReg         = CChatDelReg
CustomDestination = MyCustomDestinationUninstall
BeginPrompt = Remove.BeginPrompt
EndPrompt = Remove.EndPrompt
DelDirs	       = AppDelDir
PerUserInstall = MSChat.Stub.Remove


[MSChat.Stub.Add]
DisplayName=%CChatDesc%
ComponentID=comicchat
GUID={44BBA844-CC51-11CF-AAFA-00AA00B6015C}
Version=4,71,0,0701
Locale=EN
IsInstalled=1
StubPath=rundll32.exe advpack.dll,LaunchINFSection %17%\%InfName%,PerUserAdd

[MSChat.Stub.Add.NT]
DisplayName=%CChatDesc%
ComponentID=comicchat
GUID=%ActSetup_GUID%
Version=4,71,0,0701
Locale=EN
IsInstalled=1
StubPath=rundll32.exe advpack.dll,LaunchINFSection %17%\%InfName%,PerUserAdd.NT

[MSChat.Stub.Remove]
DisplayName=%CChatDesc%
ComponentID=comicchat
GUID=%ActSetup_GUID%
Version=4,71,0,0701
Locale=EN
IsInstalled=0
StubPath=rundll32.exe advpack.dll,LaunchINFSection %17%\%InfName%,PerUserRemove

[PerUserAdd]
UpdateInis = CChatDelOldInis, CChatInis
CustomDestination = MyCustomDestination

[PerUserAdd.NT]
UpdateInis = CChatDelOldInis, CChatInis.NT
CustomDestination = MyCustomDestination

[PerUserRemove]
UpdateInis     = CChatDelInis
CustomDestination = MyCustomDestinationUninstall
DelReg = CChatDelReg.PerUser

[MyCustomDestination]
49000,49005=DestA,5
49010,49015,49016=DestB,1
;49020=DestC,17

[MyCustomDestinationUninstall]
49000,49005=DestA,5
49010,49015=DestB,5

[DestA]
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion,ProgramFilesDir,'%PromptA%','%24%\%Program_Files%'

[DestB]
HKLM,SOFTWARE\Microsoft\%CChatName%,BaseDir,'%PromptB%','%49005%\%CChatDir%'

[DestinationDirs]
ProductFiles    = 49010
HelpFiles       = 18
InfFiles        = 17 
OldInfFiles     = 17    
SysFiles	= 11
ArtFiles     	= 49010,%ArtDir%

[OldInfFiles]
CChat11.INF,,,1

[AppDelDir]
%49010%\%ArtDir%
%49010%

[ProductFiles]
CChat.exe,,,33
README.txt,,,33
;README.GIF,,,33
LICENSE.TXT,,,33
	
[HelpFiles]
CCHAT.HLP,,,33
CCHAT.CNT,,,33

[InfFiles]
