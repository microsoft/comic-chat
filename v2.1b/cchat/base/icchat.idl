[
	uuid(241af501-8fb6-11cf-adc5-00aa00badf6f),
	version(1.0),
	helpstring("CChat Type Library")
]
library iCChatLib
{
	importlib("stdole32.tlb");
	importlib("stdole2.tlb");

	[
		uuid(241af502-8fb6-11cf-adc5-00aa00badf6f),
		helpstring("CChat Automation Server")
	]
	coclass Document
	{
		[default] interface ICChatAutomation;
	};
};
