
import "oaidl.idl";
import "ocidl.idl";

	[
		object,
		uuid(241af500-8fb6-11cf-adc5-00aa00badf6f),
		dual,
		helpstring("ICChatAutomation Interface"),
		pointer_default(unique)
	]
	interface ICChatAutomation : IDispatch
	{
		HRESULT SessionConnect( void );
		HRESULT Open( void );
		HRESULT Close( void );
		HRESULT Save( void );
		HRESULT SaveAs( void );
		HRESULT Createshortcut( void );
