HKCR,"ComicChat.Room.1\DocObject",,,"0"

HKLM,"SOFTWARE\Microsoft\Windows\CurrentVersion\App Paths\%CChatExe%",,,"%49015%\%CChatExe%"

HKLM,"SOFTWARE\Microsoft\%CChatName%",,,""
HKLM,"SOFTWARE\Microsoft\%CChatName%","BaseDir",,"%49015%"
HKLM,"SOFTWARE\Microsoft\%CChatName%","ArtDir",,"%ArtDir%"

HKCR,"mic",,,""
HKCR,"mic","URL Protocol",,""
HKCR,"mic\shell",,,""
HKCR,"mic\shell\open",""
HKCR,"mic\shell\open\command",,,"%49015%\%CChatExe% \""%%1\"""

HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\ComicChat,"DisplayName",,"%CChatDesc%"
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\ComicChat,"UninstallString",,"RunDll32 advpack.dll,LaunchINFSection %nfName%, CChatUninstall"

// Entries for Active Setup
// NO LONGER NEEDED -- The PerUserInstall section writes these entries
// HKLM,"SOFTWARE\Microsoft\Active Setup\Installed Components\%ActSetup_GUID%",,0,"%CChatDesc%"
// HKLM,"SOFTWARE\Microsoft\Active Setup\Installed Components\%ActSetup_GUID%","Version",1,---PRODVERSIONNUM---


[CChatDelReg]
HKCR,.ccr
HKCR,.ccc
HKCR,ComicChatRoomShortcut
HKCR,ComicChatTranscript
HKCR,mic
HKCR,clsid\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\ComicChat
HKCR,ComicChat.Room.1
HKCU,SOFTWARE\Microsoft\%CChatName%
HKLM,SOFTWARE\Microsoft\%CChatName%
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\"App Paths"\%CChatExe%
// Entries for Active Setup
// NO LONGER NEEDED -- The PerUserInstall section removes this entry
// HKLM,"SOFTWARE\Microsoft\Active Setup\Installed Components\%ActSetup_GUID%"

[CChatDelOldReg]
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\ComicChat

[CChatDelReg.PerUser]
HKCU,SOFTWARE\Microsoft\%CChatName%

[Remove.BeginPrompt]
Prompt="%REMOVE_CONFIRMATION_PROMPT%"
ButtonType=OKCANC
Title="%CChatDesc%"

[Remove.EndPrompt]
Prompt="%REMOVE_COMPLETION_PROMPT%"
Title="%CChatDesc%"


[Strings]
CChatDesc					= "Microsoft Chat 2.1"
CChatTop					= "Microsoft Chat 2.1"
; This is Reg Key entry name
CChatName					= "Microsoft Comic Chat"
CChat_LINK					= "Microsoft Chat"
CChatDir					= "Microsoft Chat"
CChatExe					= "CChat.exe"
Program_Files				= "Program Files"
CChat_conv					= "Microsoft Chat Conversation"
CChat_short					= "Microsoft Chat Room Shortcut"
ActSetup_GUID				= "{44BBA844-CC51-11CF-AAFA-00AA00B6015C}"

DiskName					= "Microsoft Chat 2.1 Installation Disk"
LocationPrompt				= "Install Microsoft Chat 2.1 to:"

PGMGRP_IESUITE				= "Internet Explorer"

ArtDir						= "ComicArt"
;Remember to change in SourceFiles and NfFiles also
nfName						= "CChat21.inf"

; Two-letter ID of locale/language
LOCALE_ID					= "EN"

PromptA						= "Choose your Program Files directory."
PromptB						= "Where would you like to install Microsoft Chat Files?"

REMOVE_CONFIRMATION_PROMPT = "This will remove Microsoft Chat 2.1. Make sure you are not running Microsoft Chat Application."
REMOVE_COMPLETION_PROMPT   = "Microsoft Chat 2.1 has been removed successfully."
