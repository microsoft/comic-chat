; chatsdk.INF
;
; This is the Setup information file to install 
; Microsoft Chat SDK 1.1
;
; Copyright (c) 1993-1997 Microsoft Corporation
;

[Version]
Signature="$CHICAGO$"
Provider=%MSFT%
AdvancedINF=2.5, "You need a newer version of Advpack.dll."  

[DefaultInstall]
SmartReboot = A
CopyFiles      = InfFiles, TextFiles, SpecFiles, SysFiles, SampleFiles, WebDemoFiles, TrnscrptFiles, ExecChatFiles, CheckrsFiles, ChatAdFiles, Chat2000Files, Res2000Files, Chat1jFiles
AddReg         = ChatSdkReg95
OptionDesc     = %ChatSdkDesc%
Tip            = %ChatSdkTop%
Parent         = AccessTop
InstallType    = 10
IconIndex      = 39  ;Windows Logo mini-icon for dialogs
Uninstall      = ChatSdkUninstall
CustomDestination = MyCustomDestination
UpdateInis	= AddLinks.95
RegisterOCXs	= MsChat.OCX
;RunPostSetupCommands=RunPostSetupCommandsSection

[DefaultInstall.NT]
SmartReboot = A
CopyFiles      = InfFiles, TextFiles, SpecFiles, SysFiles, SampleFiles, WebDemoFiles, TrnscrptFiles, ExecChatFiles, CheckrsFiles, ChatAdFiles, Chat2000Files, Res2000Files, Chat1jFilesNT
AddReg         = ChatSdkRegNT
OptionDesc     = %ChatSdkDesc%
Tip            = %ChatSdkTop%
Parent         = AccessTop
InstallType    = 10
IconIndex      = 39  ;Windows Logo mini-icon for dialogs
Uninstall      = ChatSdkUninstallNT
CustomDestination = MyCustomDestination
UpdateInis	= AddLinks.NT
RegisterOCXs	= MsChat.OCX
;RunPostSetupCommands=RunPostSetupCommandsSectionNT

[ChatSdkUninstall]
SmartReboot = A
BeginPrompt = Remove.BeginPrompt
EndPrompt = Remove.EndPrompt
DelFiles		= TextFiles, SpecFiles, SampleFiles, WebDemoFiles, TrnscrptFiles, ExecChatFiles, CheckrsFiles, ChatAdFiles, Chat2000Files, Res2000Files, Chat1jFiles
DelReg			= ChatSdkDelReg
CustomDestination	= MyCustomDestinationUninstall
UpdateInis		= DelLinks
DelDirs	       = AppDelDir
Cleanup	= 1

[ChatSdkUninstallNT]
SmartReboot = I
BeginPrompt = Remove.BeginPrompt
EndPrompt = Remove.EndPrompt
DelFiles		= TextFiles, SpecFiles, SampleFiles, WebDemoFiles, TrnscrptFiles, ExecChatFiles, CheckrsFiles, ChatAdFiles, Chat2000Files, Res2000Files, Chat1jFilesNT
DelReg			= ChatSdkDelRegNT
CustomDestination	= MyCustomDestinationUninstall
UpdateInis		= DelLinks
DelDirs	       = AppDelDir
Cleanup	= 1

[MyCustomDestination]
49000,49005=DestA,5
49010,49015,49016=DestB,1

[MyCustomDestinationUninstall]
49000,49005=DestA,5
49010,49015=DestB,5

[DestA]
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion,ProgramFilesDir,'%PromptA%',"%24%\%Program_Files%"

[DestB]
HKLM,SOFTWARE\Microsoft\%ChatKey%,SdkInstallDirectory,'%PromptB%',"%49005%\%ChatSdkDir%"

[DestinationDirs]
InfFiles        = 17	; LDID_INF 
SysFiles	= 11	; LDID_SYS
TextFiles     	= 49010
SpecFiles	= 49010,Specs
SampleFiles	= 49010,Samples 
Chat1jFiles	= 49010,Chat1j
Chat1jFilesNT	= 49010,Chat1j
WebDemoFiles	= 49010,Samples\WebDemo
TrnscrptFiles	= 49010,Samples\Trnscrpt 
ExecChatFiles	= 49010,Samples\ExecChat 
CheckrsFiles	= 49010,Samples\Checkrs
ChatAdFiles	= 49010,Samples\ChatAd
Chat2000Files	= 49010,Samples\Chat2000
Res2000Files	= 49010,Samples\Chat2000\Res

[AppDelDir]
%49010%\Samples\Chat2000\Res
%49010%\Samples\Chat2000
%49010%\Samples\WebDemo
%49010%\Samples\Trnscrpt
%49010%\Samples\ExecChat
%49010%\Samples\Checkrs
%49010%\Samples\ChatAd
%49010%\Chat1j
%49010%\Samples
%49010%\Specs
%49010%

[InfFiles]
ChatSdk.INF

[TextFiles]
license.txt
readme.txt
samples.txt

[SpecFiles]
chatocx.doc

[SysFiles]
; Silently don't install if newer versions exist
chatsock.dll,,,32
mschat.ocx,,,32

[BinFiles]
