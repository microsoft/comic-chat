[ChatSdkReg95]
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\%ChatSdkKey%,"DisplayName",,"%ChatSdkDesc%"
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\%ChatSdkKey%,"UninstallString",,"RunDll32 advpack.dll,LaunchINFSection %InfName%, ChatSdkUninstall"

HKLM,"SOFTWARE\Microsoft\%ChatKey%",,,""
HKLM,"SOFTWARE\Microsoft\%ChatKey%","SdkInstallDirectory",,"%49015%"

[ChatSdkDelReg]
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\%ChatSdkKey%
HKLM,"SOFTWARE\Microsoft\%ChatKey%\SdkInstallDirectory"

[ChatSdkRegNT]
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\%ChatSdkKey%,"DisplayName",,"%ChatSdkDesc%"
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\%ChatSdkKey%,"UninstallString",,"RunDll32 advpack.dll,LaunchINFSection %InfName%, ChatSdkUninstallNT"

HKLM,"SOFTWARE\Microsoft\%ChatKey%",,,""
HKLM,"SOFTWARE\Microsoft\%ChatKey%","SdkInstallDirectory",,"%49015%"

[ChatSdkDelRegNT]
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\%ChatSdkKey%
HKLM,"SOFTWARE\Microsoft\%ChatKey%\SdkInstallDirectory"

[AddLinks.95]
;Adds shortcut to SDK files 
setup.ini, progman.groups,, "Sdk=%ChatSdkDir%" ;creates folder 
setup.ini, Sdk,, """%ChatSdkDesc%"", ""%49016%""" ;creates link
setup.ini, Sdk,, """%ChatSdkReadMe%"", ""%49016%\readme.txt""" ;creates link
setup.ini, Sdk,, """%ChatSdkSamples%"", ""%49016%\samples.txt""" ;creates link
setup.ini, Sdk,, """%ChatSdkDoc%"", ""%49016%\Specs\chatocx.doc""" ;creates link
setup.ini, Sdk,, """%ChatSdkReadMe2%"", ""%49016%\chat1j\readme.txt""" ;creates link

[AddLinks.NT]
;Adds shortcut to SDK files 
setup.ini, progman.groups,, "Sdk=%ChatSdkDir%" ;creates folder 
setup.ini, Sdk,, """%ChatSdkDesc%"", """"""%49016%""""""" ;creates link
setup.ini, Sdk,, """%ChatSdkReadMe%"", """"""%49016%\readme.txt""""""" ;creates link
setup.ini, Sdk,, """%ChatSdkSamples%"", """"""%49016%\samples.txt""""""" ;creates link
setup.ini, Sdk,, """%ChatSdkDoc%"", """"""%49016%\Specs\chatocx.doc""""""" ;creates link
setup.ini, Sdk,, """%ChatSdkReadMe2%"", """"""%49016%\chat1j\readme.txt""""""" ;creates link

[DelLinks]
;Removes shortcut to SDK files during Uninstall: 
setup.ini, progman.groups,, "Sdk=%ChatSdkDir%" ;deletes folder 
setup.ini, Sdk,, """%ChatSdkDesc%""" ;deletes link
setup.ini, Sdk,, """%ChatSdkReadMe%""" ;deletes link 
setup.ini, Sdk,, """%ChatSdkSamples%""" ;deletes link
setup.ini, Sdk,, """%ChatSdkDoc%""" ;deletes link
setup.ini, Sdk,, """%ChatSdkReadMe2%""" ;deletes link

[MsChat.OCX]
%11%\MsChat.OCX

[Remove.BeginPrompt]
Prompt="%REMOVE_CONFIRMATION_PROMPT%"
ButtonType=YESNO
Title="%ChatSdkDesc%"

[Remove.EndPrompt]
Prompt="%REMOVE_COMPLETION_PROMPT%"
ButtonType=YES
Title="%ChatSdkDesc%"

[Strings]
ChatSdkDesc		= "Microsoft Chat SDK 1.1"
ChatSdkTop		= "Microsoft Chat SDK 1.1"
ChatSdkDir		= "Microsoft Chat SDK"
ChatKey			= "Microsoft Chat"
ChatSdkKey		= "MsChat SDK 1.0"
Program_Files		= "Program Files"   
ChatSdkReadMe		= "ReadMe.txt"
ChatSdkReadMe2		= "Microsoft Chat 1.0 j Readme.txt"
ChatSdkSamples		= "Samples.txt"
ChatSdkDoc		= "Microsoft Chat Control API"         
DiskName		= "Microsoft Chat SDK 1.1 Installation Disk"

;Remember to change in SourceFiles and InfFiles also
InfName			= "ChatSdk.INF"

PromptA="Choose your Program Files directory."
PromptB="Choose your Chat SDK directory."

REMOVE_CONFIRMATION_PROMPT = "This will remove Microsoft Chat SDK 1.1. Do you wish to continue?"
REMOVE_COMPLETION_PROMPT = "Microsoft Chat SDK 1.1 has been removed successfully."