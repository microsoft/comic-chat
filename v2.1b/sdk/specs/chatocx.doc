\par }{\field\flddirty{\*\fldinst {SYMBOL 183 \\f "Symbol" \\s 9.5 \\h }}{\fldrslt }}{\tab To distribute a data message being sent to the selected members, the data can be an array of bytes, shorts, longs, floats, doubles, Booleans, errors, currencies, or dates that correspond to the following VARIANT types: VT_UI1, VT_I2, VT_I4, VT_R4, VT_R8, VT_BOOL, VT_ERROR, VT_CY, VT_DATE. 
\par }\pard\plain \s40\qr\sl-160\slmult0\nowidctlpar\widctlpar\adjustright \fs12\cgrid {
