REGEDIT
; Adapted (unabashedly) from the BindScrb MFC Example
;
; This .REG file may be used by your SETUP program.
;   If a SETUP program is not available, the entries below will be
;   registered in your InitInstance automatically with a call to
;   CWinApp::RegisterShellFileTypes and COleObjectFactory::UpdateRegistryAll.

HKEY_CLASSES_ROOT\.CCR = ComicChat.Room.2
HKEY_CLASSES_ROOT\ComicChat.Room.2\shell\open\command = CHAT.EXE %1
HKEY_CLASSES_ROOT\ComicChat.Room.2\shell\open\ddeexec = [open("%1")]
HKEY_CLASSES_ROOT\ComicChat.Room.2\shell\open\ddeexec\application = Microsoft Chat
    ; note: the application is optional
    ;  (it defaults to the app name in "command")

; These lines for OLE server capability are included
; for information purposes only.  The REG file is optional, since Microsoft Chat
; will automatically register itself the first time it is run.
HKEY_CLASSES_ROOT\ComicChat.Room.2 = Microsoft Chat Room
HKEY_CLASSES_ROOT\ComicChat.Room.2\protocol\StdFileEditing\server = CHAT.EXE
HKEY_CLASSES_ROOT\ComicChat.Room.2\protocol\StdFileEditing\verb\0 = &Edit
HKEY_CLASSES_ROOT\ComicChat.Room.2\Insertable =
HKEY_CLASSES_ROOT\ComicChat.Room.2\CLSID = {241AF500-8FB6-11CF-ADC5-00AA00BADF6F}

HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F} = Microsoft Chat Room
HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\DefaultIcon = CHAT.EXE,0
HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\LocalServer32 = CHAT.EXE
HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\ProgId = ComicChat.Room.2
HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\MiscStatus = 0
HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\AuxUserType\3 = Microsoft Chat
HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\AuxUserType\2 = CChat
HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\Insertable = 
HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\TypeLib = {241AF501-8FB6-11CF-ADC5-00AA00BADF6F}
HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\verb\0 = &Edit,0,2
HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\Version = 2.5
HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\VersionIndependentProgId = ComicChat.Room
HKEY_CLASSES_ROOT\CLSID\{241AF500-8FB6-11CF-ADC5-00AA00BADF6F}\InprocHandler32 = ole32.dll
