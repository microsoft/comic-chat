TIKI.AVB,,,1
TONGTYED.AVB,,,1
XENO.AVB,,,1

FIELD.BGB,,,1
PASTORAL.BGB,,,1
ROOM.BGB,,,1

[NfFiles]
CChat25.INF,,,33

[SourceDisksNames]
1 = %DiskName%,MsChat25.CAB,0

[SourceDisksFiles]
CChat25.INF=1

CChat.exe=1
README.TXT=1
LICENSE.TXT=1
SUPPORT.TXT=1

CCHAT.HLP=1
CCHAT.CNT=1

FIELD.BGB=1
PASTORAL.BGB=1
ROOM.BGB=1

ANNA.AVB=1
ARMANDO.AVB=1
DAN.AVB=1
JORDAN.AVB=1
HUGH.AVB=1
LANCE.AVB=1
