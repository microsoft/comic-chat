; CChat25.INF
;
; This is the Setup information file to install Microsoft Chat 2.5
;
; Copyright (c) 1993-1998 Microsoft Corporation
;

#include "..\..\h\chatver.h"
; Version VER_PRODUCTVERSION

[Version]
Signature="$CHICAGO$"
Provider=%MSFT%
AdvancedINF=2.5, "You need a newer version of Advpack.dll."

[DefaultInstall]
CopyFiles      = ProductFiles, HelpFiles, NfFiles, ArtFiles
UpdateInis     = CChatDelOldInis, CChatInis
AddReg         = CChatReg
OptionDesc     = %CChatDesc%
Tip            = %CChatTop%
Parent         = AccessTop
InstallType    = 10
IconIndex      = 39  ;Windows Logo mini-icon for dialogs
Uninstall      = CChatUninstall
CustomDestination = MyCustomDestination
DelFiles       = OldInfFiles, OldArtFiles
DelReg         = CChatDelOldReg
PerUserInstall = MSChat.Stub.Add

[DefaultInstall.NT]
CopyFiles      = ProductFiles, HelpFiles, NfFiles, ArtFiles
UpdateInis     = CChatDelOldInis,CChatInis.NT
AddReg         = CChatReg
OptionDesc     = %CChatDesc%
Tip            = %CChatTop%
Parent         = AccessTop
InstallType    = 10
IconIndex      = 39  ;Windows Logo mini-icon for dialogs
Uninstall      = CChatUninstall
CustomDestination = MyCustomDestination
DelFiles       = OldInfFiles, OldArtFiles
DelReg         = CChatDelOldReg
PerUserInstall = MSChat.Stub.Add.NT

[CChatUninstall]
SmartReboot    = I
DelFiles       = ProductFilesRemove, HelpFilesRemove, ArtFilesRemove
UpdateInis     = CChatDelInis
DelReg         = CChatDelReg
CustomDestination = MyCustomDestinationUninstall
BeginPrompt    = Remove.BeginPrompt
EndPrompt      = Remove.EndPrompt
DelDirs        = AppDelDir
PerUserInstall = MSChat.Stub.Remove

[MSChat.Stub.Add]
DisplayName=%CChatDesc%
ComponentID=comicchat
GUID=%ActSetup_GUID%
Version=VER_PRODUCTVERSION
Locale=%LOCALE_ID%
IsInstalled=1
StubPath=rundll32.exe advpack.dll,LaunchINFSection %17%\%nfName%,PerUserAdd

[MSChat.Stub.Add.NT]
DisplayName=%CChatDesc%
ComponentID=comicchat
GUID=%ActSetup_GUID%
Version=VER_PRODUCTVERSION
Locale=%LOCALE_ID%
IsInstalled=1
StubPath=rundll32.exe advpack.dll,LaunchINFSection %17%\%nfName%,PerUserAdd.NT

[MSChat.Stub.Remove]
DisplayName=%CChatDesc%
ComponentID=comicchat
GUID=%ActSetup_GUID%
Version=VER_PRODUCTVERSION
Locale=%LOCALE_ID%
IsInstalled=0
StubPath=rundll32.exe advpack.dll,LaunchINFSection %17%\%nfName%,PerUserRemove

[PerUserAdd]
UpdateInis = CChatDelOldInis, CChatInis
CustomDestination = MyCustomDestination.PerUser

[PerUserAdd.NT]
UpdateInis = CChatDelOldInis, CChatInis.NT
CustomDestination = MyCustomDestination.PerUser

[PerUserRemove]
UpdateInis     = CChatDelInis
CustomDestination = MyCustomDestinationUninstall
DelReg = CChatDelReg.PerUser

[MyCustomDestination]
49000,49005=DestA,5
49010,49015,49016=DestB,1

[MyCustomDestination.PerUser]
49000,49005=DestA,5
49010,49015,49016=DestB,5

[MyCustomDestinationUninstall]
49000,49005=DestA,5
49010,49015=DestB,5

[DestA]
HKLM,SOFTWARE\Microsoft\Windows\CurrentVersion,ProgramFilesDir,'%PromptA%','%24%\%Program_Files%'

[DestB]
HKLM,SOFTWARE\Microsoft\%CChatName%,BaseDir,'%PromptB%','%49005%\%CChatDir%'

[DestinationDirs]
ProductFiles       = 49010
ProductFilesRemove = 49010
HelpFiles          = 18
HelpFilesRemove    = 18
ArtFiles           = 49010,%ArtDir%
ArtFilesRemove     = 49010,%ArtDir%
NfFiles            = 17
OldInfFiles        = 17
OldArtFiles        = 49010,%ArtDir%

[OldInfFiles]
CChat11.INF,,,1
CChat2.INF,,,1
// CChat21.INF,,,1   We don't want to remove the Win98 Setup entry so that users can reinstall MsChat21 in the future

[OldArtFiles]
FIELD.BMP,,,1
PASTORAL.BMP,,,1
ROOM.BMP,,,1

[AppDelDir]
%49010%\%DownloadDir%
%49010%\%ArtDir%
%49010%

[ProductFiles]
CChat.exe,,,4
README.TXT,,,33
LICENSE.TXT,,,33
SUPPORT.TXT,,,33

[ProductFilesRemove]
CChat.exe,,,1
README.TXT,,,1
LICENSE.TXT,,,1
SUPPORT.TXT,,,1

[HelpFiles]
CCHAT.HLP,,,33
CCHAT.CNT,,,33

[HelpFilesRemove]
CCHAT.HLP,,,1
CCHAT.CNT,,,1

[ArtFiles]
ANNA.AVB,,,33
ARMANDO.AVB,,,33
DAN.AVB,,,33
HUGH.AVB,,,33
JORDAN.AVB,,,33
LANCE.AVB,,,33
