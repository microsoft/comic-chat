MIKE.AVB=1
SUSAN.AVB=1
TIKI.AVB=1
TONGTYED.AVB=1
XENO.AVB=1

[CChatInis]
; Add the Microsoft Chat entries to the Start.Programs folder(s)

; Add to Start.Programs.Internet Explorer
setup.ini, progman.groups,, "groupies="%PGMGRP_IESUITE%""
setup.ini, groupies,, """%CChat_LINK%"", ""%49016%\%CChatExe%"""

; Add to Start.Programs
setup.ini, progman.groups,, "CChat="
setup.ini, CChat,, """%CChat_LINK%"", ""%49016%\%CChatExe%"""


[CChatInis.NT]
; Add the Microsoft Chat entries to the Start.Programs folder(s)

; Add to Start.Programs.Internet Explorer
setup.ini, progman.groups,, "groupies="%PGMGRP_IESUITE%""
setup.ini, groupies,, """%CChat_LINK%"", """"""%49016%\%CChatExe%"""""""

; Add to Start.Programs
setup.ini, progman.groups,, "CChat="
setup.ini, CChat,, """%CChat_LINK%"", """"""%49016%\%CChatExe%"""""""


[CChatDelInis]
; Remove the Microsoft Chat entries from the Start.Programs folder(s)

; Remove from Start.Programs.Internet Explorer
setup.ini, progman.groups,, "groupies="%PGMGRP_IESUITE%""
setup.ini, groupies,, """%CChat_LINK%"""

; Remove from Start.Programs
setup.ini, progman.groups,, "CChat="
setup.ini, CChat,, """%CChat_LINK%"""


[CChatDelOldInis]
setup.ini, progman.groups,, "CChat="
setup.ini, CChat,, """Microsoft Comic Chat"""


[CChatReg]
HKCR,.ccr,,,MicrosoftChatRoomShortcut
HKCR,MicrosoftChatRoomShortcut,,,%CChat_short%
HKCR,MicrosoftChatRoomShortcut,"IsShortcut",,""
HKCR,MicrosoftChatRoomShortcut,"EditFlags",1,00,00,01,00
